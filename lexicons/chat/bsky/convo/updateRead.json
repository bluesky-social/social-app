{
  "lexicon": 1,
  "id": "chat.bsky.convo.updateRead",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Updates the read state of a conversation from, optionally specifying the last read message.",
      "errors": [
        {
          "name": "InvalidConvo"
        }
      ],
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["convoId"],
          "properties": {
            "convoId": {
              "type": "string"
            },
            "messageId": {
              "type": "string"
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["convo"],
          "properties": {
            "convo": {
              "type": "ref",
              "ref": "chat.bsky.convo.defs#convoView"
            }
          }
        }
      }
    }
  }
}
