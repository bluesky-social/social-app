{
  "lexicon": 1,
  "id": "chat.bsky.group.listJoinRequests",
  "defs": {
    "main": {
      "type": "query",
      "description": "Lists a page of request to join a group (via join link) the user owns. Shows the data from the owner's point of view.",
      "errors": [
        {
          "name": "InvalidConvo"
        },
        {
          "name": "InsufficientRole"
        }
      ],
      "parameters": {
        "type": "params",
        "required": ["convoId"],
        "properties": {
          "convoId": {
            "type": "string"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["requests"],
          "properties": {
            "cursor": {
              "type": "string"
            },
            "requests": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "chat.bsky.group.defs#joinRequestView"
              }
            }
          }
        }
      }
    }
  }
}
