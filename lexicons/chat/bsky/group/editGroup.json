{
  "lexicon": 1,
  "id": "chat.bsky.group.editGroup",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Edits group settings.",
      "errors": [
        {
          "name": "ConvoLocked"
        },
        {
          "name": "InvalidConvo"
        },
        {
          "name": "InsufficientRole"
        }
      ],
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["convoId", "name"],
          "properties": {
            "convoId": {
              "type": "string"
            },
            "name": {
              "type": "string",
              "minLength": 1,
              "maxGraphemes": 50,
              "maxLength": 500
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["convo"],
          "properties": {
            "convo": {
              "type": "ref",
              "ref": "chat.bsky.convo.defs#convoView"
            }
          }
        }
      }
    }
  }
}
