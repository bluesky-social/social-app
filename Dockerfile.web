# --- Build stage: export static web app ---
FROM node:20-bookworm-slim AS builder

ENV CI=true \
    EXPO_NO_TELEMETRY=1

# Minimal build deps for any node-gyp modules used during web build
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ git ca-certificates \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy everything so link: deps (e.g., ./eslint) and patches are present
COPY . .

# Use Yarn v1 per package.json and install (include devDeps so postinstall works)
RUN corepack enable && corepack prepare yarn@1.22.22 --activate \
  && yarn config set network-timeout 600000 -g \
  && yarn install --frozen-lockfile --non-interactive

# Build static site (outputs to ./dist via your script)
RUN yarn build-web

# --- Runtime stage: serve static via nginx ---
FROM nginx:1.27-alpine AS runtime

# SPA-friendly nginx config
COPY nginx.web.conf /etc/nginx/conf.d/default.conf

# Static export from build stage
COPY --from=builder /app/dist/ /usr/share/nginx/html/

EXPOSE 80
HEALTHCHECK --interval=30s --timeout=5s --retries=3 CMD wget -qO- http://127.0.0.1/ >/dev/null 2>&1 || exit 1