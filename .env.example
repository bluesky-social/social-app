# The env the app is running in e.g. development, testflight, production
EXPO_PUBLIC_ENV=development

# This is the semver release version of the app, pulled from package.json
EXPO_PUBLIC_RELEASE_VERSION=

# This is the commit hash that the current bundle was made from.
EXPO_PUBLIC_BUNDLE_IDENTIFIER=

# Should be formatted YYMMDDHH so that it increases for each build.
EXPO_PUBLIC_BUNDLE_DATE=0

# The log level for the app's logger transports
EXPO_PUBLIC_LOG_LEVEL=debug

# Enable debug logs for specific logger instances
EXPO_PUBLIC_LOG_DEBUG=session

# Bluesky appview DID
EXPO_PUBLIC_BLUESKY_PROXY_DID=

# Chat service DID
EXPO_PUBLIC_CHAT_PROXY_DID=

#
#
# Bluesky specific values
#
#

# Bluesky's metrics API
EXPO_PUBLIC_METRICS_API_HOST=

# Growthbook config
EXPO_PUBLIC_GROWTHBOOK_API_HOST=
EXPO_PUBLIC_GROWTHBOOK_CLIENT_KEY=

# Sentry DSN for telemetry
EXPO_PUBLIC_SENTRY_DSN=

# Bitdrift API key. If undefined, Bitdrift will be disabled.
EXPO_PUBLIC_BITDRIFT_API_KEY=

# Plausible Analytics site domain, as configured in Plausible's settings. When
# set, an allowlisted subset of events is forwarded to Plausible; when unset,
# the Plausible sink is disabled and events fall back to the primary metrics
# pipeline.
EXPO_PUBLIC_PLAUSIBLE_DOMAIN=

# Plausible API host. Defaults to https://plausible.io when unset; point it at a
# self-hosted instance or a first-party proxy if needed.
EXPO_PUBLIC_PLAUSIBLE_API_HOST=

# When "true", the Plausible sink prints each event to the console and skips the
# network entirely. Useful for local development. Defaults to off.
EXPO_PUBLIC_PLAUSIBLE_DEBUG=

# geolocation web worker URL
GEOLOCATION_DEV_URL=

# Geolocation service base URL (the app fetches ${URL}/geolocation). Defaults
# to Bluesky's https://ip.bsky.app, which is CORS-locked to bsky.app, so web
# builds must point it at our first-party Bunny endpoint instead (see
# geolocation-worker/). Drives which regional moderation labelers are enabled;
# when geolocation is unavailable the app fail-closes to ALL of them.
EXPO_PUBLIC_GEOLOCATION_URL=

# live-events web worker URL
LIVE_EVENTS_DEV_URL=

# app-config web worker URL
APP_CONFIG_DEV_URL=

# Service enable flags (default true, set to 'false' to disable)
# Eurosky defaults disable these worker-backed services in standard builds.
# Exception: production web builds re-enable geolocation against our own Bunny
# endpoint (see geolocation-worker/ and deploy-web-bunny.yml) - without it the
# app force-subscribes every regional moderation labeler.
EXPO_PUBLIC_ENABLE_GEOLOCATION=false
EXPO_PUBLIC_ENABLE_LIVE_EVENTS=false
EXPO_PUBLIC_ENABLE_APP_CONFIG=false

#
#
# Live sports widget (Discover tab). See src/features/liveSports/README.md.
#
#

# Data source: football-data.org (EU-based; free tier covers the World Cup).
# Get a free token at https://www.football-data.org/client/register
#
# Production: leave the token empty and point the API URL at the first-party
# proxy (football-data-worker/), which holds the token server-side. The web
# deploy already sets this to the mu.social proxy; the proxy's own server-side
# vars (FOOTBALLDATA_TOKEN etc.) are documented in football-data-worker/README.md,
# not here - they are not EXPO_PUBLIC app vars.
#   EXPO_PUBLIC_FOOTBALLDATA_API_URL=https://sports.mu.social/v4
# Local/dev: set the token here to call football-data.org directly (no proxy).

# football-data.org API token. Direct mode only - the token is sent from the
# client, so leave this empty in production and use the proxy instead.
EXPO_PUBLIC_FOOTBALLDATA_TOKEN=

# Base URL for football-data.org, or a first-party proxy in front of it. Set
# this to the proxy host in production. Defaults to https://api.football-data.org/v4.
EXPO_PUBLIC_FOOTBALLDATA_API_URL=

# Comma-separated football-data.org competition codes. Defaults to "WC" (World
# Cup). e.g. "WC,CL,PL".
EXPO_PUBLIC_SPORTS_COMPETITION_CODES=

# Optional module title override. Unset uses a localized default ("Football").
EXPO_PUBLIC_SPORTS_TITLE=

# Kill switch. The widget auto-hides when no token/proxy is configured; set to
# 'false' to force it off even when one is.
EXPO_PUBLIC_ENABLE_SPORTS=
